# Environment Configuration for FahMai RAG System

# RAG Configuration
EMBEDDING_MODEL=intfloat/multilingual-e5-large
THAI_LLM_MODEL=KBTG-Labs/ThaiLLM-8B-Instruct
VECTOR_DB=chroma
TOP_K_RETRIEVAL=5

# Processing Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Submission Configuration
TEAM_NAME=your_id-your_thai_name

# Use lightweight mode (cross-encoder) for faster inference
# Set to 'true' for faster processing, 'false' for full Thai LLM
USE_LIGHTWEIGHT=true
