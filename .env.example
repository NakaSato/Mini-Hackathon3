# FahMai RAG System Configuration

# Set to 'true' to run ThaiLLM locally (requires GPU and 16GB+ RAM)
# Set to 'false' to use lightweight mode only (recommended for local development)
LOCAL_RUN_THAI_LLM=false

# Model configuration
EMBEDDING_MODEL=Alibaba-NLP/gte-multilingual-base
THAI_LLM_MODEL=KBTG-Labs/ThaiLLM-8B-Instruct

# Retrieval configuration
TOP_K=5
ALPHA=0.5

# Device preference (auto, cuda, mps, cpu)
DEVICE=auto
